{
  "identifier": "desktop-capability",
  "platforms": [
    "macOS",
    "windows",
    "linux"
  ],
  "windows": [
    "main"
  ],
  "permissions": [
    "autostart:default",
    "autostart:default",
    "core:app:allow-default-window-icon",
    "core:window:allow-destroy",
    "core:window:allow-hide",
    "core:window:allow-show",
    "sql:allow-execute",
    "sql:default",
    "updater:default",
    "window-state:default"
  ]
}